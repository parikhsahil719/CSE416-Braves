{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GinglesScatterResponse",
  "type": "object",
  "required": ["schemaVersion", "chartType", "state", "totalDistricts", "electionKey", "electionLabel", "selectedGroup", "units", "sampling", "points", "regressionCurves"],
  "properties": {
    "schemaVersion": { "const": "v1" },
    "chartType": { "const": "gingles-scatter" },
    "state": { "enum": ["OR", "SC"] },
    "totalDistricts": { "type": "integer", "minimum": 1 },
    "electionKey": { "const": "2024_pres" },
    "electionLabel": { "type": "string" },
    "selectedGroup": { "type": "string" },
    "units": { "type": "object", "properties": { "share": { "type": "string" } }, "required": ["share"] },
    "sampling": {
      "type": "object",
      "required": ["isSampled", "samplingAuthority", "samplingMethod", "displayedPointCount", "fullPrecinctCount", "targetPointCount"],
      "properties": {
        "isSampled": { "const": true },
        "samplingAuthority": { "const": "preprocessing" },
        "samplingMethod": { "type": "string" },
        "displayedPointCount": { "type": "integer", "minimum": 1, "maximum": 500 },
        "fullPrecinctCount": { "type": "integer", "minimum": 1 },
        "targetPointCount": { "const": 500 }
      }
    },
    "points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["precinctId", "minorityShare", "demVoteShare", "repVoteShare", "totalPopulation", "minorityPopulation"],
        "properties": {
          "precinctId": { "type": "string" },
          "precinctName": { "type": "string" },
          "minorityShare": { "type": "number", "minimum": 0, "maximum": 1 },
          "demVoteShare": { "type": "number", "minimum": 0, "maximum": 1 },
          "repVoteShare": { "type": "number", "minimum": 0, "maximum": 1 },
          "totalPopulation": { "type": "integer", "minimum": 0 },
          "minorityPopulation": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "regressionCurves": {
      "type": "array",
      "description": "Precomputed best-fit regression curve points for chart display (linear or non-linear).",
      "items": {
        "type": "object",
        "required": ["key", "label", "party", "curveType", "points"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "party": { "enum": ["DEM", "REP"] },
          "curveType": { "type": "string", "description": "Examples: best_fit, linear_regression, nonlinear_regression" },
          "points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number", "minimum": 0, "maximum": 1 },
                "y": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        }
      }
    }
  }
}
